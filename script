    helpText.Font = Enum.Font.Gotham
    helpText.TextXAlignment = Enum.TextXAlignment.Left
    helpText.TextYAlignment = Enum.TextYAlignment.Top
    helpText.Parent = sf

    local huc = Instance.new("UICorner")
    huc.CornerRadius = UDim.new(0, 5)
    huc.Parent = helpText

