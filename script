    end
end)

-- 移动端：区分点击(tap)和滑动(drag)
local touchStartPos = nil
local touchStartTime = nil
local TAP_DISTANCE = 30
local TAP_TIME = 0.3

UserInputService.TouchStarted:Connect(function(t, gp)
    if gp then return end
    touchStartPos = t.Position
    touchStartTime = tick()
end)

UserInputService.TouchEnded:Connect(function(t, gp)
    if gp then return end
    if not touchStartPos or not touchStartTime then return end
    local dist = (t.Position - touchStartPos).Magnitude
    local duration = tick() - touchStartTime
    if dist < TAP_DISTANCE and duration < TAP_TIME then
        OnUserAttack()
    end
    touchStartPos = nil
    touchStartTime = nil
end)

