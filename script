    CreateSection("操作说明")
    local helpText = Instance.new("TextLabel")
    helpText.Size = UDim2.new(1, -10, 0, IsMobile and 80 or 60)
    helpText.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
