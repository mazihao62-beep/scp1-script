-- ==================== 清理函数 ====================
local function CleanupAll()
    -- 清理所有Drawing
    for _, d in pairs(ESP_Objects) do
        for _, obj in pairs(d) do
            pcall(function() obj:Remove() end)
        end
    end
    ESP_Objects = {}

    -- 清理FOV圆圈
    pcall(function() FOVCircle:Remove() end)

    -- 清理移动端按钮
    if MenuToggleBtn then
        pcall(function() MenuToggleBtn:Destroy() end)
        MenuToggleBtn = nil
    end

    -- 断开移动端触摸连接
    for _, conn in ipairs(MobileTouchConnections) do
        pcall(function() conn:Disconnect() end)
    end
    MobileTouchConnections = {}

    -- 清理ScreenGui
    if ScreenGui then
        pcall(function() ScreenGui:Destroy() end)
    end

    -- 清理连接表
    for _, conn in ipairs(ESP_Connections) do
        pcall(function() conn:Disconnect() end)
    end
    ESP_Connections = {}

    Log("所有资源已清理", "INFO")
end

-- ==================== 核心逻辑 ====================
local function Init()
    -- 等待PlayerGui可用
    local pg = LocalPlayer:WaitForChild("PlayerGui")

    -- 将ScreenGui放入PlayerGui
    ScreenGui.Parent = pg

    -- 创建UI菜单
    local frame = CreateUI()

    -- 初始化已有玩家的ESP
    for _, plr in ipairs(Players:GetPlayers()) do
        CreateESP(plr)
    end

    -- 监听玩家加入
    local connAdd = Players.PlayerAdded:Connect(function(plr)
        CreateESP(plr)
        -- 角色重生时重建ESP
        local connChar = plr.CharacterAdded:Connect(function()
            task.wait(0.5)
            CreateESP(plr)
        end)
        table.insert(ESP_Connections, connChar)
    end)
    table.insert(ESP_Connections, connAdd)

    -- 监听玩家离开
    local connRemove = Players.PlayerRemoving:Connect(RemoveESP)
    table.insert(ESP_Connections, connRemove)

    -- 本地角色重生时：不清理ESP，等待其他玩家角色重生
    local connRespawn = LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        -- 重新创建所有玩家ESP（因为他们的角色可能变了）
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                CreateESP(plr)
            end
        end
    end)
    table.insert(ESP_Connections, connRespawn)

    -- Camera切换时更新引用（无需操作，因为GetCamera()动态获取）

    -- 移动端设置
    if IsMobile then
        SetupMobileControls()
    end

    -- PC端键盘菜单开关
    if IsPC then
        local connKey = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.KeyCode == CONFIG.UI.ToggleKey then
                MenuOpen = not MenuOpen
                frame.Visible = MenuOpen
                Log(string.format("菜单 %s", MenuOpen and "打开" or "关闭"))
            end
        end)
        table.insert(ESP_Connections, connKey)
    end

    Log(string.format("脚本已启动! [%s] | 作者:B站英吉利超入", IsMobile and "移动端" or "PC端"), "OK")
end

-- ==================== 启动 ====================
Init()

-- ==================== 主循环 ====================
RunService.RenderStepped:Connect(function()
    -- 更新FOV
    UpdateFOV()

    -- 更新ESP
    if CONFIG.ESP.Enabled then
        local success, err = pcall(UpdateESP)
        if not success then
            -- 只在有实际错误时输出（避免刷屏）
            -- 通常是因为Camera为nil或角色未加载，属于正常情况
        end
    else
        HideAllESP()
    end

    -- 自瞄逻辑
    if CONFIG.Aimbot.Enabled then
        local isActive = false

        if IsMobile then
            -- ★修复：确保菜单打开时触摸不会触发自瞄
            isActive = TouchAimActive and not MenuOpen
        else
            if CONFIG.Aimbot.KeyBind == "MouseButton2" then
                isActive = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
            elseif CONFIG.Aimbot.KeyBind == "MouseButton1" then
                isActive = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
            else
                local k = Enum.KeyCode[CONFIG.Aimbot.KeyBind]
                if k then isActive = UserInputService:IsKeyDown(k) end
            end
        end

        if isActive then
            local target, targetPart = FindTarget()
            if target then
                Aimbot.Target = target
                AimAtTarget(target, targetPart)
                TryAutoFire(target)
            else
                Aimbot.Target = nil
            end
        else
            Aimbot.Target = nil
        end
    end
end)

-- ==================== 传送/离开清理 ====================
local function OnTeleporting(state)
    if state == Enum.TeleportState.Leaving then
        CleanupAll()
    end
end

local teleportConn
teleportConn = LocalPlayer.OnTeleport:Connect(OnTeleporting)
table.insert(ESP_Connections, teleportConn)

-- 保护
local connCharRemoving = LocalPlayer.CharacterRemoving:Connect(function()
    -- 不直接清理，只是隐藏所有ESP
    HideAllESP()
end)
table.insert(ESP_Connections, connCharRemoving)
