    Instance.new("UICorner", MenuToggleBtn).CornerRadius = UDim.new(0, 12)
    local bs = Instance.new("UIStroke", MenuToggleBtn); bs.Color = Color3.fromRGB(50, 200, 255); bs.Thickness = 1.5

    MenuToggleBtn.MouseButton1Click:Connect(function()
        local sg = CoreGui:FindFirstChild("MyScriptUI")
        if sg then
            local mf = sg:FindFirstChild("MainFrame"); local ff = sg:FindFirstChild("FloatFrame")
            if mf then local v = not mf.Visible; mf.Visible = v; if ff then ff.Visible = not v end end
        end
    end)

    local function onTouchStart(t, gp)
        if gp then return end
        local sg = CoreGui:FindFirstChild("MyScriptUI")
        if sg then local mf = sg:FindFirstChild("MainFrame"); if mf and mf.Visible then return end end
        Aimbot.TouchPos = t.Position
        task.delay(TOUCH_AIM_DELAY, function() if Aimbot.TouchPos then TouchAimActive = true end end)
    end
    local function onTouchMove(t, gp) if Aimbot.TouchPos then Aimbot.TouchPos = t.Position end end
    local function onTouchEnd(t, gp) TouchAimActive = false; Aimbot.TouchPos = nil; Aimbot.Target = nil end

    table.insert(MobileTouchConnections, UserInputService.TouchStarted:Connect(onTouchStart))
    table.insert(MobileTouchConnections, UserInputService.TouchMoved:Connect(onTouchMove))
    table.insert(MobileTouchConnections, UserInputService.TouchEnded:Connect(onTouchEnd))
end

local function CustomNotify(title, text, duration)
    duration = duration or 2
    Log(title .. (text ~= "" and " - " .. text or ""))
    local n = Instance.new("Frame")
    n.Size = UDim2.new(0, 220, 0, 60); n.Position = UDim2.new(1, 10, 1, -10)
    n.AnchorPoint = Vector2.new(1,1); n.BackgroundColor3 = Color3.fromRGB(30,30,30)
    n.BackgroundTransparency = 0.1; n.BorderSizePixel = 0; n.Parent = CoreGui
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)
    local s = Instance.new("UIStroke", n); s.Thickness = 1.5; s.Color = Color3.fromRGB(100,200,100)
    local tl = Instance.new("TextLabel", n)
    tl.Size = UDim2.new(1,-16,0,20); tl.Position = UDim2.new(0,8,0,6)
    tl.BackgroundTransparency = 1; tl.Font = Enum.Font.SourceSansBold; tl.TextSize = 14
    tl.TextColor3 = Color3.new(1,1,1); tl.TextXAlignment = Enum.TextXAlignment.Left; tl.Text = title
    local cl = Instance.new("TextLabel", n)
    cl.Size = UDim2.new(1,-16,0,18); cl.Position = UDim2.new(0,8,0,30)
    cl.BackgroundTransparency = 1; cl.Font = Enum.Font.SourceSans; cl.TextSize = 13
    cl.TextColor3 = Color3.fromRGB(220,220,220); cl.TextXAlignment = Enum.TextXAlignment.Left; cl.Text = text
    n.Position = UDim2.new(1, 240, 1, -10)
    TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { Position = UDim2.new(1, -230, 1, -10) }):Play()
    task.delay(duration, function()
        if not n.Parent then return end
        local ot = TweenService:Create(n, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(1, 240, 1, -10) })
        ot:Play(); ot.Completed:Connect(function() pcall(function() n:Destroy() end) end)
    end)
end
