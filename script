local function GetTeamName(plr)
    local team = plr.Team
    if not team then return "无队伍" end
    return TeamNames[team.Name] or team.Name
end

local function GetTeamColor(plr)
    local team = plr.Team
    return team and team.TeamColor.Color or Color3.fromRGB(180, 180, 180)
end

local function Log(m, l)
    l = l or "INFO"
    local t = l == "OK" and "[✓]" or l == "ERR" and "[✖]" or "[SCP]"
    print(t, m)
end

local function IsValid(plr)
    if plr == LocalPlayer then return false end
    if not plr.Character then return false end
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if plr:GetAttribute("InRun") == false then return false end
    return true
end

local function IsSameTeam(plr)
    if not plr.Team or not LocalPlayer.Team then return false end
    return plr.Team == LocalPlayer.Team
end

local function ShouldESP(plr)
    if not IsValid(plr) then return false end
    if CONFIG.ESP.TeamCheck and IsSameTeam(plr) then return false end
    return true
end

local function ShouldAimbot(plr)
    if not IsValid(plr) then return false end
    if CONFIG.Aimbot.TeamCheck and IsSameTeam(plr) then return false end
    return true
end

local function IsVisible(from, to)
    if not CONFIG.Aimbot.WallCheck then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character, Workspace.CurrentCamera}
    local result = Workspace:Raycast(from, (to - from).Unit * (to - from).Magnitude, params)
    return not result
end

local function GetPart(char, name)
    if not char then return nil end
    if name == "Head" then return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    elseif name == "HumanoidRootPart" then return char:FindFirstChild("HumanoidRootPart")
    elseif name == "Random" then
        for _, n in ipairs({"Head", "HumanoidRootPart", "UpperTorso", "Torso"}) do
            local p = char:FindFirstChild(n); if p then return p end
        end
        return char:FindFirstChild("HumanoidRootPart")
    end
    return char:FindFirstChild(name) or char:FindFirstChild("HumanoidRootPart")
end

