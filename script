FOVCircle.Radius = CONFIG.Aimbot.FOV
FOVCircle.Color = Color3.fromRGB(50, 200, 255)
FOVCircle.Filled = false
FOVCircle.Visible = false

local function UpdateFOV()
    local cam = GetCamera()
    if not cam then FOVCircle.Visible = false; return end
    FOVCircle.Visible = (CONFIG.Aimbot.Enabled and CONFIG.Aimbot.ShowFOV)
    if not FOVCircle.Visible then return end
    FOVCircle.Radius = CONFIG.Aimbot.FOV
    if IsMobile then
        FOVCircle.Position = Aimbot.TouchPos or (cam.ViewportSize / 2)
    else
        FOVCircle.Position = UserInputService:GetMouseLocation()
    end
end

local function CreateESP(plr)
    if ESP_Objects[plr] then return end
    local d = {}
    local function make(key, drawType, props)
        local ok, obj = pcall(Drawing.new, drawType)
        if not ok then return end
        for pk, pv in pairs(props or {}) do pcall(function() obj[pk] = pv end) end
        obj.Visible = false
        d[key] = obj
    end
    make("Box", "Square", { Thickness = 1, Filled = false })
    make("Line", "Line", { Thickness = 1 })
    make("Name", "Text", { Center = true, Outline = true, Size = IsMobile and 12 or 14 })
    make("Distance", "Text", { Center = true, Outline = true, Size = IsMobile and 10 or 12 })
    make("HealthBg", "Square", { Thickness = 0, Filled = true, Color = Color3.fromRGB(30, 30, 30) })
    make("HealthBar", "Square", { Thickness = 0, Filled = true })
    ESP_Objects[plr] = d
end

local function RemoveESP(plr)
    local d = ESP_Objects[plr]
    if d then
        for _, obj in pairs(d) do pcall(function() obj:Remove() end) end
        ESP_Objects[plr] = nil
    end
end

local function HideAllESP()
    for _, d in pairs(ESP_Objects) do
        if d then for _, obj in pairs(d) do pcall(function() obj.Visible = false end) end end
    end
end

local function UpdateESP()
    local cam = GetCamera()
    if not cam then HideAllESP(); return end
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then HideAllESP(); return end

    for plr, drawings in pairs(ESP_Objects) do
        if not drawings then continue end
        if not ShouldTargetESP(plr) then
            for _, obj in pairs(drawings) do pcall(function() obj.Visible = false end) end
            continue
        end
        local char = plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not root or not head or not hum then
            for _, obj in pairs(drawings) do pcall(function() obj.Visible = false end) end
            continue
        end
        local dist = (root.Position - myRoot.Position).Magnitude
        if dist > CONFIG.ESP.MaxDistance then
            for _, obj in pairs(drawings) do pcall(function() obj.Visible = false end) end
            continue
        end
        local ok1, headPos, onScreenH = pcall(cam.WorldToViewportPoint, cam, head.Position + Vector3.new(0, 0.5, 0))
        local ok2, rootPos, onScreenR = pcall(cam.WorldToViewportPoint, cam, root.Position - Vector3.new(0, 0.2, 0))
        if not ok1 or not ok2 or (not onScreenH and not onScreenR) then
            for _, obj in pairs(drawings) do pcall(function() obj.Visible = false end) end
            continue
        end
        local isPvP = IsPVPEnabled(plr)
        local color = (CONFIG.ESP.TeamCheck and not isPvP) and CONFIG.ESP.TeamColor or CONFIG.ESP.Color
        local boxH = math.abs(headPos.Y - rootPos.Y)
        local boxW = math.max(boxH * 0.65, 4)
        local boxX = rootPos.X - boxW / 2
        local boxY = rootPos.Y

        if drawings.Box then pcall(function()
            drawings.Box.Size = Vector2.new(boxW, math.max(boxH, 4))
            drawings.Box.Position = Vector2.new(boxX, boxY - boxH)
            drawings.Box.Color = color; drawings.Box.Visible = CONFIG.ESP.Box
        end) end
        if drawings.Line then pcall(function()
            local ss = cam.ViewportSize; local ox, oy
            if CONFIG.ESP.TracerOrigin == "Middle" then ox, oy = ss.X/2, ss.Y/2
            elseif CONFIG.ESP.TracerOrigin == "Mouse" then
                if IsMobile and Aimbot.TouchPos then ox, oy = Aimbot.TouchPos.X, Aimbot.TouchPos.Y
                elseif not IsMobile then local m = UserInputService:GetMouseLocation(); ox, oy = m.X, m.Y
                else ox, oy = ss.X/2, ss.Y end
            else ox, oy = ss.X/2, ss.Y end
            drawings.Line.From = Vector2.new(ox, oy); drawings.Line.To = Vector2.new(rootPos.X, rootPos.Y)
            drawings.Line.Color = color; drawings.Line.Visible = CONFIG.ESP.Line
        end) end
        if drawings.Name then pcall(function()
            drawings.Name.Text = plr.Name; drawings.Name.Position = Vector2.new(rootPos.X, boxY - boxH - 18)
            drawings.Name.Color = color; drawings.Name.Visible = CONFIG.ESP.Name
        end) end
        if drawings.Distance then pcall(function()
            drawings.Distance.Text = string.format("%.0f [%s]", dist, isPvP and "⚔" or "✓")
            drawings.Distance.Position = Vector2.new(rootPos.X, boxY + 2)
            drawings.Distance.Color = Color3.fromRGB(200,200,200); drawings.Distance.Visible = CONFIG.ESP.Distance
        end) end
        if drawings.HealthBar and drawings.HealthBg then pcall(function()
            local hp = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
            drawings.HealthBg.Size = Vector2.new(4, boxH); drawings.HealthBg.Position = Vector2.new(boxX-6, boxY-boxH)
            drawings.HealthBg.Visible = CONFIG.ESP.HealthBar
            drawings.HealthBar.Size = Vector2.new(4, math.max(boxH*hp, 0))
            drawings.HealthBar.Position = Vector2.new(boxX-6, boxY-boxH+boxH*(1-hp))
            drawings.HealthBar.Color = Color3.fromRGB(math.floor((1-hp)*255), math.floor(hp*255), 0)
            drawings.HealthBar.Visible = CONFIG.ESP.HealthBar
        end) end
    end
end
local function FindTarget()
    local cam = GetCamera()
    if not cam then return nil, nil end
    local closestDist = CONFIG.Aimbot.FOV
    local closestPlr, closestPart = nil, nil
    local centerPos = (IsMobile and Aimbot.TouchPos) or UserInputService:GetMouseLocation()

    for _, plr in ipairs(Players:GetPlayers()) do
        if not ShouldTargetAimbot(plr) then continue end
        local tp = GetCharacterPart(plr.Character, CONFIG.Aimbot.AimAt)
        if not tp then continue end
        local ok, pos, onScreen = pcall(cam.WorldToViewportPoint, cam, tp.Position)
        if not ok or not onScreen then continue end
        local screenDist = (Vector2.new(pos.X, pos.Y) - centerPos).Magnitude
        if screenDist < closestDist then
            closestDist = screenDist; closestPlr = plr; closestPart = tp
        end
    end
    return closestPlr, closestPart
end

local function AimAtTarget(target, targetPart)
    if not target or not targetPart then return end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local targetPos = targetPart.Position
    if CONFIG.Aimbot.Prediction > 0 then
        local tr = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if tr then
            targetPos = targetPos + tr.Velocity * ((myRoot.Position - targetPos).Magnitude / 120) * CONFIG.Aimbot.Prediction
        end
    end
    local lookAtCF = CFrame.lookAt(myRoot.Position, targetPos) * CFrame.Angles(0, math.rad(180), 0)
    if CONFIG.Aimbot.Smoothness < 1 then
        myRoot.CFrame = myRoot.CFrame:Lerp(lookAtCF, 1 - CONFIG.Aimbot.Smoothness)
    else
        myRoot.CFrame = lookAtCF
    end
end

local function TryAutoFire(target)
    if not CONFIG.Aimbot.AutoFire or not target or not target.Character then return end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot or not tRoot then return end
    if (myRoot.Position - tRoot.Position).Magnitude > CONFIG.Aimbot.AutoFireRange then return end
    local function tryEquip(t)
        if not t or not t:IsA("Tool") then return false end
        if t.Parent ~= myChar then
            if not pcall(function() t.Parent = myChar end) then return false end
            task.wait(0.05)
        end
        if t.Parent == myChar then pcall(function() t:Activate() end); return true end
        return false
    end
    local eq = myChar:FindFirstChildOfClass("Tool")
    if eq then tryEquip(eq); return end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then for _, t in ipairs(bp:GetChildren()) do if tryEquip(t) then break end end end
end

