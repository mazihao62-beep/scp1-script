-- ==================== 工具函数 ====================
local function Log(msg, level)
    level = level or "INFO"
    local colors = { INFO = "[SCP]", WARN = "[⚠]", ERR = "[✖]", OK = "[✓]" }
    print(string.format("%s %s", colors[level] or "[SCP]", msg))
end

local function IsPlayerValid(plr)
    if plr == LocalPlayer then return false end
    if not plr.Character then return false end
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local inRun = plr:GetAttribute("InRun")
    if inRun == false then return false end
    return true
end

local function IsPVPEnabled(plr)
    return plr:GetAttribute("PVPOff") ~= true
end

local function ShouldTargetESP(plr)
    if not IsPlayerValid(plr) then return false end
    if CONFIG.ESP.TeamCheck then return IsPVPEnabled(plr) end
    return true
end

local function ShouldTargetAimbot(plr)
    if not IsPlayerValid(plr) then return false end
    if CONFIG.Aimbot.TeamCheck then return IsPVPEnabled(plr) end
    return true
end

local function GetCharacterPart(character, partName)
    if partName == "Head" then
        return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    elseif partName == "HumanoidRootPart" then
        return character:FindFirstChild("HumanoidRootPart")
    elseif partName == "Random" then
        for _, name in ipairs({"Head", "HumanoidRootPart", "UpperTorso", "Torso"}) do
            local p = character:FindFirstChild(name)
            if p then return p end
        end
        return character:FindFirstChild("HumanoidRootPart")
    end
    return character:FindFirstChild(partName) or character:FindFirstChild("HumanoidRootPart")
end

