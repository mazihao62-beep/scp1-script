-- ===== 清理 =====
local function Clean()
    for _, d in pairs(ESP_Objects) do if d then for _, o in pairs(d) do pcall(function() o:Remove() end) end end end
    ESP_Objects = {}; pcall(function() FOVC:Remove() end)
    if MenuBtn then pcall(function() MenuBtn:Destroy() end); MenuBtn = nil end
    for _, c in ipairs(MobileTouchCons) do pcall(function() c:Disconnect() end) end; MobileTouchCons = {}
    for _, c in ipairs(ESP_Connections) do pcall(function() c:Disconnect() end) end; ESP_Connections = {}
    pcall(function() local s = CoreGui:FindFirstChild("MyScriptUI"); if s then s:Destroy() end end)
end

-- ===== 启动 =====
local function Init()
    CreateUI(); SetupMobile()
    for _, p in ipairs(Players:GetPlayers()) do MkESP(p) end
    table.insert(ESP_Connections, Players.PlayerAdded:Connect(function(p)
        MkESP(p)
        table.insert(ESP_Connections, p.CharacterAdded:Connect(function() task.wait(0.5); MkESP(p) end))
    end))
    table.insert(ESP_Connections, Players.PlayerRemoving:Connect(RmESP))
    table.insert(ESP_Connections, LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then MkESP(p) end end
    end))
    if not IsMobile then
        table.insert(ESP_Connections, UserInputService.InputBegan:Connect(function(inp, gp)
            if gp then return end
            if inp.KeyCode == Enum.KeyCode.RightShift then
                local s = CoreGui:FindFirstChild("MyScriptUI")
                if s then local m = s:FindFirstChild("MainFrame"); local f = s:FindFirstChild("FloatFrame")
                    if m then local v = not m.Visible; m.Visible = v; if f then f.Visible = not v end end end
            end
        end))
    end
    table.insert(ESP_Connections, LocalPlayer.OnTeleport:Connect(function(s)
        if s == Enum.TeleportState.Leaving then Clean() end
    end))
    Log("启动成功 "..(IsMobile and "移动端" or "PC端"), "OK")
    Notify("SCP异常站点", "脚本已加载 | 作者:B站英吉利超入", 3)
end

Init()

-- ===== 主循环 =====
RunService.RenderStepped:Connect(function()
    pcall(UpdFOV)
    if CONFIG.ESP.Enabled then pcall(UpdESP) else pcall(HideESP) end

    -- 瞄准系统：自瞄转向 + 静默命中
    if CONFIG.Aimbot.Enabled then
        local t, tp = FindTarget()
        if t then
            Aimbot.Target = t; Aimbot.TargetPart = tp
            AimAt(t, tp)
        else
            Aimbot.Target = nil; Aimbot.TargetPart = nil
        end
    else
        Aimbot.Target = nil; Aimbot.TargetPart = nil
    end
end)
