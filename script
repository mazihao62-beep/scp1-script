-- ESP
local function MkESP(plr)
    if ESP_Objects[plr] then return end
    local d = {}
    local function mk(k, t, props)
        local ok, o = pcall(Drawing.new, t); if not ok then return end
        for pk, pv in pairs(props or {}) do pcall(function() o[pk] = pv end) end
        o.Visible = false; d[k] = o
    end
    mk("Box", "Square", { Thickness = 1, Filled = false })
    mk("Line", "Line", { Thickness = 1 })
    mk("Name", "Text", { Center = true, Outline = true, Size = 14 })
    mk("Team", "Text", { Center = true, Outline = true, Size = 12 })
    mk("Dist", "Text", { Center = true, Outline = true, Size = 12 })
    mk("HbBg", "Square", { Thickness = 0, Filled = true, Color = Color3.fromRGB(30, 30, 30) })
    mk("Hb", "Square", { Thickness = 0, Filled = true })
    ESP_Objects[plr] = d
end

local function RmESP(plr)
    local d = ESP_Objects[plr]
    if d then for _, o in pairs(d) do pcall(function() o:Remove() end) end; ESP_Objects[plr] = nil end
end

local function HideESP()
    for _, d in pairs(ESP_Objects) do
        if d then for _, o in pairs(d) do pcall(function() o.Visible = false end) end end
    end
end

local function UpdESP()
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local mc = LocalPlayer.Character; local mr = mc and mc:FindFirstChild("HumanoidRootPart")
    if not mr then return end
    for plr, d in pairs(ESP_Objects) do
        if not d then continue end
        if not ShouldESP(plr) then
            for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue
        end
        local c = plr.Character; local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChild("Head"); local hm = c and c:FindFirstChildOfClass("Humanoid")
        if not r or not h or not hm then
            for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue
        end
        local dist = (r.Position - mr.Position).Magnitude
        if dist > CONFIG.ESP.MaxDistance then
            for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue
        end
        local hp, oh = nil, false; local rp, or_ = nil, false
        pcall(function() hp, oh = cam:WorldToViewportPoint(h.Position + Vector3.new(0, 0.5, 0)) end)
        pcall(function() rp, or_ = cam:WorldToViewportPoint(r.Position - Vector3.new(0, 0.2, 0)) end)
        if not hp or not rp or (not oh and not or_) then
            for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue
        end
        local tcol = GetTeamColor(plr)
        local bh = math.abs(hp.Y - rp.Y); local bw = math.max(bh * 0.65, 4)
        local bx = rp.X - bw / 2; local by = rp.Y

        if d.Box then pcall(function()
            d.Box.Size = Vector2.new(bw, math.max(bh, 4)); d.Box.Position = Vector2.new(bx, by - bh)
            d.Box.Color = tcol; d.Box.Visible = CONFIG.ESP.Box
        end) end
        if d.Line then pcall(function()
            local ss = cam.ViewportSize; local ox, oy
            if CONFIG.ESP.TracerOrigin == "Middle" then ox, oy = ss.X/2, ss.Y/2
            elseif CONFIG.ESP.TracerOrigin == "Mouse" then
                if not IsMobile then local m = UserInputService:GetMouseLocation(); ox, oy = m.X, m.Y
                else ox, oy = ss.X/2, ss.Y end
            else ox, oy = ss.X/2, ss.Y end
            d.Line.From = Vector2.new(ox, oy); d.Line.To = Vector2.new(rp.X, rp.Y)
            d.Line.Color = tcol; d.Line.Visible = CONFIG.ESP.Line
        end) end
        if d.Name then pcall(function()
            d.Name.Text = plr.Name; d.Name.Position = Vector2.new(rp.X, by - bh - 30)
            d.Name.Color = CONFIG.ESP.Color; d.Name.Visible = CONFIG.ESP.Name
        end) end
        if d.Team then pcall(function()
            d.Team.Text = GetTeamName(plr); d.Team.Position = Vector2.new(rp.X, by - bh - 16)
            d.Team.Color = tcol; d.Team.Visible = CONFIG.ESP.TeamName
        end) end
        if d.Dist then pcall(function()
            d.Dist.Text = string.format("%.0f studs", dist)
            d.Dist.Position = Vector2.new(rp.X, by + 2); d.Dist.Color = Color3.fromRGB(200,200,200)
            d.Dist.Visible = CONFIG.ESP.Distance
        end) end
        if d.Hb and d.HbBg then pcall(function()
            local hpct = math.clamp(hm.Health / hm.MaxHealth, 0, 1)
            d.HbBg.Size = Vector2.new(4, bh); d.HbBg.Position = Vector2.new(bx - 6, by - bh)
            d.HbBg.Visible = CONFIG.ESP.HealthBar
            d.Hb.Size = Vector2.new(4, math.max(bh * hpct, 0))
            d.Hb.Position = Vector2.new(bx - 6, by - bh + bh * (1 - hpct))
            d.Hb.Color = Color3.fromRGB(math.floor((1 - hpct) * 255), math.floor(hpct * 255), 0)
            d.Hb.Visible = CONFIG.ESP.HealthBar
        end) end
    end
end
-- ===== 自瞄+静默瞄准（合并，共用参数） =====
-- 自瞄：自动转向最近敌人
-- 静默：手动攻击时强制命中目标
-- 不自动攻击

local function FindTarget()
    local cam = Workspace.CurrentCamera
    if not cam then return nil, nil end
    local closest = CONFIG.Aimbot.FOV; local cp, cpart = nil, nil
    local center
    if IsMobile then
        center = cam.ViewportSize / 2
    else
        center = UserInputService:GetMouseLocation()
    end

    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil, nil end

    for _, plr in ipairs(Players:GetPlayers()) do
        if not ShouldAimbot(plr) then continue end
        local tp = GetPart(plr.Character, CONFIG.Aimbot.AimAt)
        if not tp then continue end
        local tr = plr.Character:FindFirstChild("HumanoidRootPart")
        if tr then
            local d = (myRoot.Position - tr.Position).Magnitude
            if d > CONFIG.Aimbot.MaxDistance then continue end
        end
        if CONFIG.Aimbot.WallCheck and tr then
            if not IsVisible(myRoot.Position, tr.Position) then continue end
        end
        local pos, on = nil, false
        pcall(function() pos, on = cam:WorldToViewportPoint(tp.Position) end)
        if not pos or not on then continue end
        local sd = (Vector2.new(pos.X, pos.Y) - center).Magnitude
        if sd < closest then closest = sd; cp = plr; cpart = tp end
    end
    return cp, cpart
end

-- 自瞄转向
local function AimAt(tg, tp)
    if not tg or not tp then return end
    local mc = LocalPlayer.Character; if not mc then return end
    local mr = mc:FindFirstChild("HumanoidRootPart"); if not mr then return end
    local pos = tp.Position
    if CONFIG.Aimbot.Prediction > 0 then
        local tr = tg.Character and tg.Character:FindFirstChild("HumanoidRootPart")
        if tr then
            pos = pos + tr.Velocity * ((mr.Position - pos).Magnitude / 120) * CONFIG.Aimbot.Prediction
        end
    end
    local cf = CFrame.lookAt(mr.Position, pos) * CFrame.Angles(0, math.rad(180), 0)
    if CONFIG.Aimbot.Smoothness < 1 then
        mr.CFrame = mr.CFrame:Lerp(cf, 1 - CONFIG.Aimbot.Smoothness)
    else
        mr.CFrame = cf
    end
end

-- 静默命中：用户攻击时强制命中目标
local function SilentHit(tg, tp)
    if not tg or not tp then return end
    local mc = LocalPlayer.Character
    if not mc then return end
    local tool = mc:FindFirstChildOfClass("Tool")
    if not tool then
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") then
                    pcall(function() t.Parent = mc end)
                    task.wait()
                    tool = t; break
                end
            end
        end
    end
    if not tool then return end
    local hitEvent = tool:FindFirstChild("WeaponHitEvent")
    if not hitEvent then
        for _, child in ipairs(tool:GetDescendants()) do
            if child:IsA("RemoteEvent") and child.Name:find("Hit") then
                hitEvent = child; break
            end
        end
    end
    if not hitEvent then return end
    pcall(function() hitEvent:FireServer(tp) end)
end

-- 监听用户攻击输入
local function OnUserAttack()
    if not CONFIG.Aimbot.Enabled then return end
    if not Aimbot.Target or not Aimbot.TargetPart then return end
    SilentHit(Aimbot.Target, Aimbot.TargetPart)
end

