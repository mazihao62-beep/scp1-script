-- ==================== ESP ====================
local function CreateESP(plr)
    if ESP_Objects[plr] then
        -- 玩家已存在，重置Drawing可见性
        for _, d in pairs(ESP_Objects[plr]) do
            d.Visible = false
        end
        return
    end

    local d = {}
    local function make(key, drawType, props)
        local obj = Drawing.new(drawType)
        for pk, pv in pairs(props or {}) do obj[pk] = pv end
        obj.Visible = false
        d[key] = obj
        return obj
    end

    make("Box", "Square", { Thickness = 1, Filled = false })
    make("Line", "Line", { Thickness = 1 })
    make("Name", "Text", { Center = true, Outline = true, Size = IsMobile and 12 or 14 })
    make("Distance", "Text", { Center = true, Outline = true, Size = IsMobile and 10 or 12 })
    make("HealthBg", "Square", { Thickness = 0, Filled = true, Color = Color3.fromRGB(30, 30, 30) })
    make("HealthBar", "Square", { Thickness = 0, Filled = true })

    ESP_Objects[plr] = d
end

local function RemoveESP(plr)
    local d = ESP_Objects[plr]
    if d then
        for _, obj in pairs(d) do
            pcall(function() obj:Remove() end)
        end
        ESP_Objects[plr] = nil
    end
end

local function HideAllESP()
    for _, d in pairs(ESP_Objects) do
        for _, obj in pairs(d) do
            obj.Visible = false
        end
    end
end

local function UpdateESP()
    local cam = GetCamera()
    if not cam then
        HideAllESP()
        return
    end

    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then
        HideAllESP()
        return
    end

    for plr, drawings in pairs(ESP_Objects) do
        -- 检查玩家是否有效
        if not ShouldTargetESP(plr) then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end

        local char = plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if not root or not head or not hum then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end

        -- 距离检测
        local dist = (root.Position - myRoot.Position).Magnitude
        if dist > CONFIG.ESP.MaxDistance then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end

        -- 屏幕坐标
        local headPos, onScreenH = cam:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local rootPos, onScreenR = cam:WorldToViewportPoint(root.Position - Vector3.new(0, 0.2, 0))

        if not onScreenH and not onScreenR then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end

        local isPvP = IsPVPEnabled(plr)
        local color = (CONFIG.ESP.TeamCheck and not isPvP) and CONFIG.ESP.TeamColor or CONFIG.ESP.Color

        local boxH = math.abs(headPos.Y - rootPos.Y)
        local boxW = boxH * 0.65
        local boxX = rootPos.X - boxW / 2
        local boxY = rootPos.Y

        -- 方框
        if drawings.Box then
            drawings.Box.Size = Vector2.new(math.max(boxW, 4), math.max(boxH, 4))
            drawings.Box.Position = Vector2.new(boxX, boxY - boxH)
            drawings.Box.Color = color
            drawings.Box.Visible = CONFIG.ESP.Box
        end

        -- 底线
        if drawings.Line then
            local ss = cam.ViewportSize
            local ox, oy
            if CONFIG.ESP.TracerOrigin == "Middle" then
                ox, oy = ss.X / 2, ss.Y / 2
            elseif CONFIG.ESP.TracerOrigin == "Mouse" then
                if IsMobile and Aimbot.TouchPos then
                    ox, oy = Aimbot.TouchPos.X, Aimbot.TouchPos.Y
                else
                    local m = UserInputService:GetMouseLocation()
                    ox, oy = m.X, m.Y
                end
            else -- Bottom
                ox, oy = ss.X / 2, ss.Y
            end
            drawings.Line.From = Vector2.new(ox, oy)
            drawings.Line.To = Vector2.new(rootPos.X, rootPos.Y)
            drawings.Line.Color = color
            drawings.Line.Visible = CONFIG.ESP.Line
        end

        -- 名字
        if drawings.Name then
            drawings.Name.Text = plr.Name
            drawings.Name.Position = Vector2.new(rootPos.X, boxY - boxH - 18)
            drawings.Name.Color = color
            drawings.Name.Visible = CONFIG.ESP.Name
        end

        -- 距离
        if drawings.Distance then
            drawings.Distance.Text = string.format("%.0f [%s]", dist, isPvP and "⚔" or "✓")
            drawings.Distance.Position = Vector2.new(rootPos.X, boxY + 2)
            drawings.Distance.Color = Color3.fromRGB(200, 200, 200)
            drawings.Distance.Visible = CONFIG.ESP.Distance
        end

        -- 血条
        if drawings.HealthBar and drawings.HealthBg then
            local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            local bw = 4
            local bx = boxX - 6

            drawings.HealthBg.Size = Vector2.new(bw, boxH)
            drawings.HealthBg.Position = Vector2.new(bx, boxY - boxH)
            drawings.HealthBg.Visible = CONFIG.ESP.HealthBar

            drawings.HealthBar.Size = Vector2.new(bw, math.max(boxH * hp, 0))
            drawings.HealthBar.Position = Vector2.new(bx, boxY - boxH + boxH * (1 - hp))
            drawings.HealthBar.Color = Color3.fromRGB(
                math.floor((1 - hp) * 255),
                math.floor(hp * 255),
                0
            )
            drawings.HealthBar.Visible = CONFIG.ESP.HealthBar
        end
    end
end
-- ==================== 自瞄 ====================
local function FindTarget()
    local cam = GetCamera()
    if not cam then return nil, nil end

    local closestDist = CONFIG.Aimbot.FOV
    local closestPlr, closestPart = nil, nil
    local centerPos

    if IsMobile and Aimbot.TouchPos then
        centerPos = Aimbot.TouchPos
    else
        centerPos = UserInputService:GetMouseLocation()
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if not ShouldTargetAimbot(plr) then continue end
        local tp = GetCharacterPart(plr.Character, CONFIG.Aimbot.AimAt)
        if not tp then continue end
        local pos, onScreen = cam:WorldToViewportPoint(tp.Position)
        if not onScreen then continue end
        local screenDist = (Vector2.new(pos.X, pos.Y) - centerPos).Magnitude
        if screenDist < closestDist then
            closestDist = screenDist
            closestPlr = plr
            closestPart = tp
        end
    end
    return closestPlr, closestPart
end

local function AimAtTarget(target, targetPart)
    if not target or not targetPart then return end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local targetPos = targetPart.Position

    -- 提前量预测
    if CONFIG.Aimbot.Prediction > 0 then
        local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            local vel = targetRoot.Velocity
            local dist = (myRoot.Position - targetPos).Magnitude
            local travelTime = dist / 120
            targetPos = targetPos + vel * travelTime * CONFIG.Aimbot.Prediction
        end
    end

    local lookAtCF = CFrame.lookAt(myRoot.Position, targetPos) * CFrame.Angles(0, math.rad(180), 0)
    if CONFIG.Aimbot.Smoothness < 1 then
        myRoot.CFrame = myRoot.CFrame:Lerp(lookAtCF, 1 - CONFIG.Aimbot.Smoothness)
    else
        myRoot.CFrame = lookAtCF
    end
end

local function TryAutoFire(target)
    if not CONFIG.Aimbot.AutoFire or not target or not target.Character then return end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot or not tRoot then return end
    if (myRoot.Position - tRoot.Position).Magnitude > CONFIG.Aimbot.AutoFireRange then return end

    local function tryEquipAndAttack(tool)
        if not tool or not tool:IsA("Tool") then return false end
        if tool.Parent ~= myChar then
            local success = pcall(function() tool.Parent = myChar end)
            if not success then return false end
            task.wait(0.05)
        end
        if tool.Parent == myChar then
            pcall(function() tool:Activate() end)
            return true
        end
        return false
    end

    local equipped = myChar:FindFirstChildOfClass("Tool")
    if equipped then tryEquipAndAttack(equipped); return end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if tryEquipAndAttack(t) then break end
        end
    end
end

-- ==================== 移动端触摸控制 ====================
local TouchAimActive = false
local MenuToggleBtn = nil
local MobileTouchConnections = {}

local function SetupMobileControls()
    if not IsMobile then return end

    -- 查找或创建安全可用的父级ScreenGui
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local targetParent = playerGui:FindFirstChild("SCPScriptUI") or playerGui

    -- 创建浮动菜单按钮
    MenuToggleBtn = Instance.new("TextButton")
    MenuToggleBtn.Name = "SCPMenuToggle"
    MenuToggleBtn.Size = UDim2.new(0, 50, 0, 50)
    MenuToggleBtn.Position = UDim2.new(0.95, -55, 0.05, 5)
    MenuToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    MenuToggleBtn.BackgroundTransparency = 0.15
    MenuToggleBtn.BorderSizePixel = 0
    MenuToggleBtn.Text = "⚙"
    MenuToggleBtn.TextColor3 = Color3.fromRGB(50, 200, 255)
    MenuToggleBtn.TextSize = 24
    MenuToggleBtn.Font = Enum.Font.GothamBold
    MenuToggleBtn.Active = true
    MenuToggleBtn.Draggable = true
    MenuToggleBtn.Parent = targetParent

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 12)
    btnCorner.Parent = MenuToggleBtn

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = Color3.fromRGB(50, 200, 255)
    btnStroke.Thickness = 1.5
    btnStroke.Parent = MenuToggleBtn

    -- ⚙按钮点击开关菜单
    local btnConnection = MenuToggleBtn.MouseButton1Click:Connect(function()
        MenuOpen = not MenuOpen
        if Frame then Frame.Visible = MenuOpen end
        Log(string.format("菜单 %s", MenuOpen and "打开" or "关闭"))
    end)
    table.insert(MobileTouchConnections, btnConnection)

    -- 触摸自瞄：手指按下开启，松手关闭
    local function onTouchStart(touch, gameProcessed)
        -- 如果菜单开着，不启动自瞄
        if MenuOpen then return end
        -- 如果被UI消费了（按到了按钮等），不启动自瞄
        if gameProcessed then return end
        Aimbot.TouchPos = touch.Position
        TouchAimActive = true
    end

    local function onTouchMove(touch, gameProcessed)
        -- 即使gameProcessed为true，只要自瞄活跃就更新位置
        -- 但菜单打开时不更新
        if MenuOpen then return end
        if TouchAimActive then
            Aimbot.TouchPos = touch.Position
        end
    end

    local function onTouchEnd(touch, gameProcessed)
        -- ★修复关键Bug：无论gameProcessed是什么，只要自瞄活跃就关闭
        -- 避免触摸UI元素后自瞄卡死
        if TouchAimActive then
            TouchAimActive = false
            Aimbot.TouchPos = nil
            Aimbot.Target = nil
        end
    end

    local conn1 = UserInputService.TouchStarted:Connect(onTouchStart)
    local conn2 = UserInputService.TouchMoved:Connect(onTouchMove)
    local conn3 = UserInputService.TouchEnded:Connect(onTouchEnd)

    table.insert(MobileTouchConnections, conn1)
    table.insert(MobileTouchConnections, conn2)
    table.insert(MobileTouchConnections, conn3)

    Log("移动端触摸控制已启用 | 屏幕⚙按钮开关菜单 | 触摸屏幕自瞄", "OK")
end

