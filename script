    ESP_Objects = {}; pcall(function() FOVCircle:Remove() end)
    if MenuToggleBtn then pcall(function() MenuToggleBtn:Destroy() end); MenuToggleBtn = nil end
    for _, c in ipairs(MobileTouchConnections) do pcall(function() c:Disconnect() end) end
    MobileTouchConnections = {}
    for _, c in ipairs(ESP_Connections) do pcall(function() c:Disconnect() end) end
    ESP_Connections = {}
    pcall(function() local s = CoreGui:FindFirstChild("MyScriptUI"); if s then s:Destroy() end end)
end

local function Init()
    CreateUI(); SetupMobileControls()
    for _, p in ipairs(Players:GetPlayers()) do CreateESP(p) end
    table.insert(ESP_Connections, Players.PlayerAdded:Connect(function(p)
        CreateESP(p)
        table.insert(ESP_Connections, p.CharacterAdded:Connect(function() task.wait(0.5); CreateESP(p) end))
    end))
    table.insert(ESP_Connections, Players.PlayerRemoving:Connect(RemoveESP))
    table.insert(ESP_Connections, LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
    end))
    if not IsMobile then
        table.insert(ESP_Connections, UserInputService.InputBegan:Connect(function(inp, gp)
            if gp then return end
            if inp.KeyCode == Enum.KeyCode.RightShift then
                local s = CoreGui:FindFirstChild("MyScriptUI")
                if s then local m = s:FindFirstChild("MainFrame"); local f = s:FindFirstChild("FloatFrame")
                    if m then local v = not m.Visible; m.Visible = v; if f then f.Visible = not v end end end
            end
        end))
    end
    table.insert(ESP_Connections, LocalPlayer.OnTeleport:Connect(function(s) if s == Enum.TeleportState.Leaving then CleanupAll() end end))
    Log(string.format("启动[%s]", IsMobile and "移动端" or "PC端"), "OK")
    CustomNotify("SCP异常站点", "脚本已加载 | 作者:B站英吉利超入", 3)
end

Init()

RunService.RenderStepped:Connect(function()
    pcall(UpdateFOV)
    if CONFIG.ESP.Enabled then pcall(UpdateESP) else pcall(HideAllESP) end
    if CONFIG.Aimbot.Enabled then
        local a = IsMobile and TouchAimActive or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        if a then local t, tp = FindTarget()
            if t then Aimbot.Target = t; AimAtTarget(t, tp); TryAutoFire(t) else Aimbot.Target = nil end
        else Aimbot.Target = nil end
    end
end)
