                if p:GetAttribute("InRun") ~= false then validCount = validCount + 1 end
                if p:GetAttribute("PVPOff") ~= true then pvpCount = pvpCount + 1 end
            end
        end

        local platform = IsMobile and "📱移动端" or "🖥 PC端"
        StatusText.Text = string.format("▶ %s | 玩家:%d 有效:%d PVP:%d", platform, playerCount, validCount, pvpCount)
    end
-- ====== UI控件生成 ======
