-- ESP
local function MkESP(plr)
    if ESP_Objects[plr] then return end
    local d = {}
    local function mk(k, t, props)
        local ok, o = pcall(Drawing.new, t); if not ok then return end
        for pk, pv in pairs(props or {}) do pcall(function() o[pk] = pv end) end
        o.Visible = false; d[k] = o
    end
    mk("Box", "Square", { Thickness = 1, Filled = false })
    mk("Line", "Line", { Thickness = 1 })
    mk("Name", "Text", { Center = true, Outline = true, Size = IsMobile and 12 or 14 })
    mk("Dist", "Text", { Center = true, Outline = true, Size = IsMobile and 10 or 12 })
    mk("HbBg", "Square", { Thickness = 0, Filled = true, Color = Color3.fromRGB(30, 30, 30) })
    mk("Hb", "Square", { Thickness = 0, Filled = true })
    ESP_Objects[plr] = d
end

local function RmESP(plr)
    local d = ESP_Objects[plr]
    if d then for _, o in pairs(d) do pcall(function() o:Remove() end) end; ESP_Objects[plr] = nil end
end

local function HideESP()
    for _, d in pairs(ESP_Objects) do
        if d then for _, o in pairs(d) do pcall(function() o.Visible = false end) end end
    end
end

local function UpdESP()
    local cam = Workspace.CurrentCamera
    if not cam then HideESP(); return end
    local mc = LocalPlayer.Character; local mr = mc and mc:FindFirstChild("HumanoidRootPart")
    if not mr then HideESP(); return end
    for plr, d in pairs(ESP_Objects) do
        if not d then continue end
        if not ShouldESP(plr) then for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue end
        local c = plr.Character; local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChild("Head"); local hm = c and c:FindFirstChildOfClass("Humanoid")
        if not r or not h or not hm then for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue end
        local dist = (r.Position - mr.Position).Magnitude
        if dist > CONFIG.ESP.MaxDistance then for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue end
        local ok1, hp, oh = pcall(cam.WorldToViewportPoint, cam, h.Position + Vector3.new(0, 0.5, 0))
        local ok2, rp, or_ = pcall(cam.WorldToViewportPoint, cam, r.Position - Vector3.new(0, 0.2, 0))
        if not ok1 or not ok2 or (not oh and not or_) then for _, o in pairs(d) do pcall(function() o.Visible = false end) end; continue end
        local pvp = IsPvP(plr)
        local col = (CONFIG.ESP.TeamCheck and not pvp) and CONFIG.ESP.TeamColor or CONFIG.ESP.Color
        local bh = math.abs(hp.Y - rp.Y); local bw = math.max(bh * 0.65, 4)
        local bx = rp.X - bw / 2; local by = rp.Y
        if d.Box then pcall(function()
            d.Box.Size = Vector2.new(bw, math.max(bh, 4)); d.Box.Position = Vector2.new(bx, by - bh)
            d.Box.Color = col; d.Box.Visible = CONFIG.ESP.Box
        end) end
        if d.Line then pcall(function()
            local ss = cam.ViewportSize; local ox, oy
            if CONFIG.ESP.TracerOrigin == "Middle" then ox, oy = ss.X/2, ss.Y/2
            elseif CONFIG.ESP.TracerOrigin == "Mouse" then
                if IsMobile and Aimbot.TouchPos then ox, oy = Aimbot.TouchPos.X, Aimbot.TouchPos.Y
                elseif not IsMobile then local m = UserInputService:GetMouseLocation(); ox, oy = m.X, m.Y
                else ox, oy = ss.X/2, ss.Y end
            else ox, oy = ss.X/2, ss.Y end
            d.Line.From = Vector2.new(ox, oy); d.Line.To = Vector2.new(rp.X, rp.Y); d.Line.Color = col; d.Line.Visible = CONFIG.ESP.Line
        end) end
        if d.Name then pcall(function()
            d.Name.Text = plr.Name; d.Name.Position = Vector2.new(rp.X, by - bh - 18); d.Name.Color = col; d.Name.Visible = CONFIG.ESP.Name
        end) end
        if d.Dist then pcall(function()
            d.Dist.Text = string.format("%.0f [%s]", dist, pvp and "⚔" or "✓")
            d.Dist.Position = Vector2.new(rp.X, by + 2); d.Dist.Color = Color3.fromRGB(200,200,200); d.Dist.Visible = CONFIG.ESP.Distance
        end) end
        if d.Hb and d.HbBg then pcall(function()
            local hpct = math.clamp(hm.Health / hm.MaxHealth, 0, 1)
            d.HbBg.Size = Vector2.new(4, bh); d.HbBg.Position = Vector2.new(bx - 6, by - bh); d.HbBg.Visible = CONFIG.ESP.HealthBar
            d.Hb.Size = Vector2.new(4, math.max(bh * hpct, 0)); d.Hb.Position = Vector2.new(bx - 6, by - bh + bh * (1 - hpct))
            d.Hb.Color = Color3.fromRGB(math.floor((1 - hpct) * 255), math.floor(hpct * 255), 0); d.Hb.Visible = CONFIG.ESP.HealthBar
        end) end
    end
end
-- ===== 自瞄 + 子弹追踪 =====
local function FindTarget()
    local cam = Workspace.CurrentCamera
    if not cam then return nil, nil end
    local closest = CONFIG.Aimbot.FOV; local cp, cpart = nil, nil
    local center = (IsMobile and Aimbot.TouchPos) or UserInputService:GetMouseLocation()
    for _, plr in ipairs(Players:GetPlayers()) do
        if not ShouldAim(plr) then continue end
        local tp = GetPart(plr.Character, CONFIG.Aimbot.AimAt)
        if not tp then continue end
        local ok, pos, on = pcall(cam.WorldToViewportPoint, cam, tp.Position)
        if not ok or not on then continue end
        local sd = (Vector2.new(pos.X, pos.Y) - center).Magnitude
        if sd < closest then closest = sd; cp = plr; cpart = tp end
    end
    return cp, cpart
end

local function AimAt(tg, tp)
    if not tg or not tp then return end
    local mc = LocalPlayer.Character; if not mc then return end
    local mr = mc:FindFirstChild("HumanoidRootPart"); if not mr then return end
    local pos = tp.Position
    if CONFIG.Aimbot.Prediction > 0 then
        local tr = tg.Character and tg.Character:FindFirstChild("HumanoidRootPart")
        if tr then
            pos = pos + tr.Velocity * ((mr.Position - pos).Magnitude / 120) * CONFIG.Aimbot.Prediction
        end
    end
    local cf = CFrame.lookAt(mr.Position, pos) * CFrame.Angles(0, math.rad(180), 0)
    if CONFIG.Aimbot.Smoothness < 1 then
        mr.CFrame = mr.CFrame:Lerp(cf, 1 - CONFIG.Aimbot.Smoothness)
    else
        mr.CFrame = cf
    end
end

local lastAttackTime = 0
local function BulletTrack(tg)
    if not CONFIG.Aimbot.AutoFire or not tg or not tg.Character then return end
    local mc = LocalPlayer.Character; if not mc then return end
    local mr = mc:FindFirstChild("HumanoidRootPart")
    local tr = tg.Character:FindFirstChild("HumanoidRootPart")
    if not mr or not tr then return end
    local dist = (mr.Position - tr.Position).Magnitude
    if dist > CONFIG.Aimbot.AutoFireRange then return end

    local now = tick()
    if now - lastAttackTime < 0.3 then return end
    lastAttackTime = now

    local function DoAttack(tool)
        if not tool or not tool:IsA("Tool") then return false end
        if tool.Parent ~= mc then
            local ok = pcall(function() tool.Parent = mc end)
            if not ok then return false end
            task.wait()
        end
        if tool.Parent == mc then
            pcall(function() tool:Activate() end)
            return true
        end
        return false
    end

    local eq = mc:FindFirstChildOfClass("Tool")
    if eq then DoAttack(eq); return end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if DoAttack(t) then break end
        end
    end
end

