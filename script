-- ==================== 核心逻辑 ====================
local function Init()
    local pg = LocalPlayer:WaitForChild("PlayerGui")
    ScreenGui.Parent = pg
    local frame = CreateUI()

    for _, plr in ipairs(Players:GetPlayers()) do
        CreateESP(plr)
        plr.CharacterAdded:Connect(function() task.wait(0.5); CreateESP(plr) end)
    end

    Players.PlayerAdded:Connect(function(plr)
        CreateESP(plr)
        plr.CharacterAdded:Connect(function() task.wait(0.5); CreateESP(plr) end)
    end)
    Players.PlayerRemoving:Connect(RemoveESP)

    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == CONFIG.UI.ToggleKey then
            MenuOpen = not MenuOpen; frame.Visible = MenuOpen
            Log(string.format("菜单 %s", MenuOpen and "打开" or "关闭"))
        end
    end)

    Log("脚本已启动! RightShift=菜单 | 按住右键自瞄", "OK")
end

-- ==================== 主循环 ====================
Init()

RunService.RenderStepped:Connect(function()
    UpdateFOV()

    if CONFIG.ESP.Enabled then
        pcall(UpdateESP)
    else
        for _, d in pairs(ESP_Objects) do
            for _, o in pairs(d) do o.Visible = false end
        end
    end

    if CONFIG.Aimbot.Enabled then
        local isDown = false
        if CONFIG.Aimbot.KeyBind == "MouseButton2" then
            isDown = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        elseif CONFIG.Aimbot.KeyBind == "MouseButton1" then
            isDown = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
        else
            local k = Enum.KeyCode[CONFIG.Aimbot.KeyBind]
            if k then isDown = UserInputService:IsKeyDown(k) end
        end

        if isDown then
            local target, targetPart = FindTarget()
            if target then
                Aimbot.Target = target
                AimAtTarget(target, targetPart)
                TryAutoFire(target)
            else
                Aimbot.Target = nil
            end
        else
            Aimbot.Target = nil
        end
    end
end)

