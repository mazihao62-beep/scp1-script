        for k in cfgPath:gmatch("[%w_]+") do table.insert(keys, k) end

        local function getCfg()
            local t = CONFIG
            for i = 1, #keys do t = t[keys[i]] end
            return t
        end

        local function setCfg(v)
            local t = CONFIG
            for i = 1, #keys - 1 do t = t[keys[i]] end
            t[keys[#keys]] = v
        end

        local function updateDisplay()
            local v = getCfg()
            slider.Text = tostring(v)
            valLabel.Text = tostring(v)
        end
        updateDisplay()

        slider.FocusLost:Connect(function(enter)
            if enter then
                local nv = tonumber(slider.Text)
                if nv then
                    nv = math.clamp(nv, minv, maxv)
                    if step then nv = math.floor(nv / step + 0.5) * step end
                    setCfg(nv)
                    updateDisplay()
                    Log(string.format("设置 [%s] = %s", text, tostring(nv)))
                else
                    updateDisplay()
                end
            else
                updateDisplay()
            end
        end)
    end

    -- 更新状态栏
    local function UpdateStatus()
        local playerCount = 0
        local validCount = 0
        local pvpCount = 0

